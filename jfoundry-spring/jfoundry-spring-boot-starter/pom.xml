<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>org.jfoundry</groupId>
        <artifactId>jfoundry-spring</artifactId>
        <version>1.0.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>jfoundry-spring-boot-starter</artifactId>
    <name>jfoundry-spring-boot-starter</name>
    <description>
        Aggregate Spring Boot starter for jfoundry. It exposes a stable user-facing entry point
        while aggregating the current default runtime adapters: MyBatis-Plus persistence,
        Transactional Outbox MyBatis-Plus storage, Spring messaging, and Spring Outbox runtime.
        This pom contains no code — business side just imports this artifact.
    </description>

    <dependencies>
        <!-- All AutoConfigurations live here; business side gets Spring Boot auto-wiring by
             depending on this starter transitively. -->
        <dependency>
            <groupId>org.jfoundry</groupId>
            <artifactId>jfoundry-autoconfigure</artifactId>
        </dependency>

        <!-- Aggregate current default runtime implementations. Adapter-specific artifactIds stay
             below this starter so user projects do not depend on implementation modules directly. -->
        <dependency>
            <groupId>org.jfoundry</groupId>
            <artifactId>jfoundry-domain</artifactId>
        </dependency>
        <dependency>
            <groupId>org.jfoundry</groupId>
            <artifactId>jfoundry-persistence-core</artifactId>
        </dependency>
        <dependency>
            <groupId>org.jfoundry</groupId>
            <artifactId>jfoundry-messaging-core</artifactId>
        </dependency>
        <dependency>
            <groupId>org.jfoundry</groupId>
            <artifactId>jfoundry-messaging-jackson</artifactId>
        </dependency>
        <dependency>
            <groupId>org.jfoundry</groupId>
            <artifactId>jfoundry-persistence-mybatis-plus</artifactId>
        </dependency>
        <dependency>
            <groupId>org.jfoundry</groupId>
            <artifactId>jfoundry-outbox-mybatis-plus</artifactId>
        </dependency>
        <dependency>
            <groupId>org.jfoundry</groupId>
            <artifactId>jfoundry-outbox-spring</artifactId>
        </dependency>
    </dependencies>
</project>
